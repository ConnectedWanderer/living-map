{
  "name": "ingestion-worker",
  "version": "1.0.0",
  "description": "One-shot job that polls RSS sources and persists normalized events",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --test --experimental-strip-types tests/unit/*.test.ts",
    "test:all": "npm test && npm run test:int",
    "test:int": "node --experimental-strip-types tests/integration-runner.ts",
    "docker:build:mock-feed": "docker build -t living-map/mock-feed:latest ../mock-feed",
    "docker:build": "npm run docker:build:mock-feed",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/ tests/",
    "format": "biome format --write src/ tests/",
    "check": "biome check --write src/ tests/ && node scripts/check-jsdoc.mjs",
    "check:docs": "node scripts/check-jsdoc.mjs",
    "lint:ci": "biome ci src/ tests/ && node scripts/check-jsdoc.mjs"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@testcontainers/postgresql": "^12.0.0",
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "testcontainers": "^12.0.0",
    "typescript": "^6.0.3"
  }
}
