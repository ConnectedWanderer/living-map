{
  "name": "ingestion-worker",
  "version": "1.0.0",
  "description": "Cron-triggered service that polls sources, normalizes, deduplicates, enriches, and persists events",
  "type": "module",
  "scripts": {
    "start": "node --experimental-strip-types src/index.ts",
    "test": "node --test --experimental-strip-types tests/unit/*.test.ts",
    "test:all": "npm test && npm run test:int",
    "test:int": "node --experimental-strip-types tests/integration-runner.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "node-cron": "^4.2.1",
    "pg": "^8.20.0",
    "pino": "^10.3.1"
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "@types/pg": "^8.20.0",
    "node-pg-migrate": "^8.0.4",
    "typescript": "^6.0.3"
  }
}
