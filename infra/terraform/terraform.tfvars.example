# ─────────────────────────────────────────────
# OCI Authentication
# ─────────────────────────────────────────────
region               = "us-ashburn-1"
tenancy_ocid         = "ocid1.tenancy.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
compartment_ocid     = "ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
user_ocid            = "ocid1.user.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
api_fingerprint      = "aa:bb:cc:dd:ee:ff:gg:hh:ii:jj:kk:ll:mm:nn:oo:pp"
api_private_key_path = "~/.oci/oci_api_key.pem"
ssh_public_key_path  = "~/.ssh/living-map.pub"

# ─────────────────────────────────────────────
# Object Storage (for Terraform remote state)
# ─────────────────────────────────────────────
tenancy_namespace    = "your-tenancy-namespace"
# state_bucket_name  = "living-map-terraform-state"  # default, override if needed

# ─────────────────────────────────────────────
# Instance configuration
# ─────────────────────────────────────────────
# availability_domain_number = 2  # uncomment if AD-1 returns "out of capacity"
# image_ocid                 = "ocid1.image.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"  # uncomment to pin a specific image
# instance_ocpus             = 1   # default (minimal free-tier, scale up if needed)
# instance_memory_gb         = 6   # default (minimal free-tier, scale up if needed)
